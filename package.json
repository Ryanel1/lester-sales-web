{
  "name": "lester-sales-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "tsx --test src/lib/*.test.ts",
    "test:e2e": "playwright test",
    "test:all": "npm run lint && npm run typecheck && npm test && npm run build && npm run test:e2e",
    "check:secrets": "node scripts/check-secrets.mjs",
    "check:links": "node --env-file=.env.local scripts/check-external-links.mjs",
    "smoke:publishers": "node --env-file=.env.local scripts/smoke-publishers.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.7",
    "next": "latest",
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "tsx": "^4.23.1",
    "typescript": "latest"
  }
}
