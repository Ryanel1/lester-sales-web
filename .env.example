# Required in production. Use a long, randomly generated value for the session secret.
PORTAL_PASSWORD=replace-with-customer-password
PORTAL_SESSION_SECRET=replace-with-at-least-32-random-characters

# Dedicated LesterSales.net Supabase project only.
NEXT_PUBLIC_SUPABASE_URL=https://your-lester-sales-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=replace-with-publishable-key
SUPABASE_SECRET_KEY=replace-with-server-only-secret-key

# Comma-separated Supabase Auth emails allowed to use /admin.
PORTAL_ADMIN_EMAILS=admin@lestersales.net
